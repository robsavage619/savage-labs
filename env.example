# Copy to .env and fill in values.
# ── Paths ─────────────────────────────────────────────────────────────────────
DATA_DIR=data

# ── Database ──────────────────────────────────────────────────────────────────
# DB_ENCRYPTION_KEY is fetched from Keychain at boot; set via: shc auth set-db-key

# ── WHOOP OAuth ───────────────────────────────────────────────────────────────
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://127.0.0.1:8000/auth/whoop/callback

# ── Hevy ──────────────────────────────────────────────────────────────────────
# HEVY_API_KEY stored in Keychain (shc.hevy.access_token.v1)

# ── Server ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
